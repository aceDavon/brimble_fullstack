# Postgres connection
DATABASE_URL=postgres://brimble:brimble@db:5432/brimble

# Docker socket path inside the api container
DOCKER_SOCKET=/var/run/docker.sock

# BuildKit container name (must match docker-compose service name)
BUILDKIT_HOST=docker-container://buildkit

# Caddy admin API (internal network)
CADDY_ADMIN_URL=http://caddy:2019

# Port the API listens on
PORT=3000

# Public base URL — used to construct live URLs for deployments
# On a clean local machine this is just http://localhost
PUBLIC_BASE_URL=http://localhost
